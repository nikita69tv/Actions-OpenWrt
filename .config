# Базовый конфиг для архитектуры MediaTek
CONFIG_TARGET_mediatek=y

# Стандартные настройки образа
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=128

# Базовые настройки системы
CONFIG_LUCI_LANG_ru=y
CONFIG_PACKAGE_luci-ssl=y

# Все остальные пакеты и выбор модели (AX3200/AX3000T) 
# добавятся автоматически через GitHub Actions Matrix.
